{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ENABLE_TOOL_SEARCH": "1"
  },
  "permissions": {
    "allow": [
      "Bash(codex review:*)",
      "Bash(npm view:*)",
      "Bash(cat:*)",
      "Bash(gemini:*)",
      "Bash(gh api:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(ls:*)",
      "Bash(lsd:*)",
      "Bash(rg:*)",
      "Bash(trash:*)",
      "Bash(fd:*)",
      "Bash(npm run*)",
      "Bash(pnpm run*)",
      "Bash(yarn run*)",
      "Bash(moon check*)",
      "Bash(moon fmt*)",
      "Bash(moon info*)",
      "Bash(moon test*)",
      "Bash(deno check*)",
      "Bash(deno fmt*)",
      "Bash(deno info*)",
      "Bash(deno test*)",
      "Read(.env.example)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(mongod:*)",
      "Bash(mysql:*)",
      "Bash(nc:*)",
      "Bash(npm remove:*)",
      "Bash(npm uninstall:*)",
      "Bash(psql:*)",
      "Bash(rm:*)",
      "Bash(sudo:*)",
      "Bash(wget:*)",
      "Read(**/*token*)",
      "Read(**/.ssh/**)",
      "Read(.env)",
      "Write(**/secrets/**)",
      "Write(.env)",
      "Write(oxlint.config.ts)",
      "NotebookEdit",
      "WebSearch",
      "WebFetch"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(find *)|Bash(rm *)|Bash(grep *)",
            "command": "$CLAUDE_CONFIG_DIR/hooks/guard-commands.sh"
          }
        ]
      },
      {
        "matcher": "WebSearch",
        "hooks": [
          {
            "type": "agent",
            "prompt": "WebSearchツールが「$ARGUMENTS」というクエリで呼ばれました。代わりに /tavily スキルを使って検索を実行し、結果を返してください。",
            "model": "haiku",
            "timeout": 30,
            "statusMessage": "Tavilyサブエージェントで検索中..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(**/.github/workflows/*.yml)|Edit(**/.github/workflows/*.yaml)|Write(**/.github/workflows/*.yml)|Write(**/.github/workflows/*.yaml)",
            "command": "$CLAUDE_CONFIG_DIR/hooks/lint-github-actions.sh"
          },
          {
            "type": "command",
            "if": "Edit(**/*.sh)|Write(**/*.sh)",
            "command": "$CLAUDE_CONFIG_DIR/hooks/lint-shell.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "agent-slack-log",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$CLAUDE_CONFIG_DIR/statusline.py"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "discord@claude-plugins-official": true,
    "aws-serverless@agent-plugins-for-aws": true,
    "databases-on-aws@agent-plugins-for-aws": true,
    "deploy-on-aws@agent-plugins-for-aws": true,
    "migration-to-aws@agent-plugins-for-aws": true
  },
  "extraKnownMarketplaces": {
    "agent-plugins-for-aws": {
      "source": {
        "source": "github",
        "repo": "awslabs/agent-plugins"
      }
    }
  },
  "language": "japanese",
  "plansDirectory": ".agents/plans",
  "autoUpdates": false
}
