model = "gpt-5.5"
model_reasoning_effort = "xhigh"
cli_auth_credentials_store = "auto"
notify = ["terminal-notifier", "-title", "🤖 Codex", "-message", "処理が完了しました", "-group", "codex-completion"]

[notice]
"hide_gpt-5.1-codex-max_migration_prompt" = true

[features]
skills = true
multi_agent = true
smart_approvals = true
codex_hooks = true

[tui]
status_line = ["model-with-reasoning", "context-remaining", "model-name", "project-root", "git-branch", "context-used", "five-hour-limit", "weekly-limit"]

[plugins."github@openai-curated"]
enabled = true

[plugins."google-calendar@openai-curated"]
enabled = true

[plugins."gmail@openai-curated"]
enabled = true

[plugins."slack@openai-curated"]
enabled = true

[plugins."notion@openai-curated"]
enabled = true

[plugins."build-ios-apps@openai-curated"]
enabled = true

[mcp_servers.chrome-devtools]
command = "chrome-devtools-mcp"
args = ["--autoConnect"]

[mcp_servers.chrome-devtools.tools.new_page]
approval_mode = "approve"

[mcp_servers.chrome-devtools.tools.performance_start_trace]
approval_mode = "approve"

{{ include "chezmoi_ignores/private/codex_projects.toml" }}
