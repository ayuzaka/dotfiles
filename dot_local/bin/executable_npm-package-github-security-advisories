#!/usr/bin/env bash

package_name="$1"
if [[ -z "$package_name" ]]; then
  echo "usage: npm-package-github-security-advisories <package_name>" >&2
  exit 1
fi

repo_path="$(npm-package-github-repo "$package_name")" || exit 1
gh api "repos/$repo_path/security-advisories" --jq '.[] | {ghsa: .ghsa_id, severity, summary}'
