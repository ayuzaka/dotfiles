{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 9999,
  "env": {
    "ENABLE_TOOL_SEARCH": "1",
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "permissions": {
    "allow": [
      "Bash(codex review:*)",
      "Bash(npm view:*)",
      "Bash(cat:*)",
      "Bash(gemini:*)",
      "Bash(gh api:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(ls:*)",
      "Bash(lsd:*)",
      "Bash(rg:*)",
      "Bash(trash:*)",
      "Bash(fd:*)",
      "Bash(npm run*)",
      "Bash(pnpm run*)",
      "Bash(yarn run*)",
      "Bash(moon check*)",
      "Bash(moon fmt*)",
      "Bash(moon info*)",
      "Bash(moon test*)",
      "Bash(deno check*)",
      "Bash(deno fmt*)",
      "Bash(deno info*)",
      "Bash(deno test*)",
      "Read(.env.example)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Read"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(mongod:*)",
      "Bash(mysql:*)",
      "Bash(nc:*)",
      "Bash(npm remove:*)",
      "Bash(npm uninstall:*)",
      "Bash(psql:*)",
      "Bash(rm:*)",
      "Bash(sudo:*)",
      "Bash(wget:*)",
      "Read(**/.ssh/**)",
      "Read(.env)",
      "Write(.env)",
      "NotebookEdit",
      "WebSearch",
      "WebFetch"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_CONFIG_DIR/hooks/guard-commands.sh",
            "if": "Bash(find *)|Bash(rm *)|Bash(grep *)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_CONFIG_DIR/hooks/lint-github-actions.sh",
            "if": "Edit(**/.github/workflows/*.yml)|Edit(**/.github/workflows/*.yaml)|Write(**/.github/workflows/*.yml)|Write(**/.github/workflows/*.yaml)"
          },
          {
            "type": "command",
            "command": "$CLAUDE_CONFIG_DIR/hooks/lint-shell.sh",
            "if": "Edit(**/*.sh)|Write(**/*.sh)"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_CONFIG_DIR/hooks/notify.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "agent-slack-log",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$CLAUDE_CONFIG_DIR/statusline.py"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "discord@claude-plugins-official": true,
    "aws-serverless@agent-plugins-for-aws": true,
    "databases-on-aws@agent-plugins-for-aws": true,
    "deploy-on-aws@agent-plugins-for-aws": true,
    "migration-to-aws@agent-plugins-for-aws": true
  },
  "extraKnownMarketplaces": {
    "agent-plugins-for-aws": {
      "source": {
        "source": "github",
        "repo": "awslabs/agent-plugins"
      }
    }
  },
  "language": "japanese",
  "effortLevel": "high",
  "advisorModel": "opus",
  "plansDirectory": ".agents/plans",
  "agentPushNotifEnabled": true
}

