{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "rm *": "deny",
      "sudo": "deny",
      "git push *": "deny",
      "git reset *": "deny",
      "gh auth *": "deny",
      "sudo *": "deny",
      "wget *": "deny",
      "cat": "allow",
      "fd": "allow",
      "grep": "allow",
      "rg": "allow",
      "mkdir": "allow",
      "ls": "allow",
      "lsd": "allow",
      "which": "allow",
      "touch": "allow",
      "echo": "allow",
      "sort": "allow",
      "wc": "allow",
      "ghq *": "allow",
      "*": "ask"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "*.env.*.example": "allow"
    },
    "write": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "*.env.*.example": "allow"
    }
  },
  "lsp": true,
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "chrome-devtools-mcp"
      ]
    }
  },
  "tools": {
    "web_search": false
  },
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"]
}
