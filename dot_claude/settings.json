{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 9999,
  "env": {
    "ENABLE_TOOL_SEARCH": "1",
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "permissions": {
    "allow": [
      "Bash(codex review:*)",
      "Bash(npm view:*)",
      "Bash(cat:*)",
      "Bash(gemini:*)",
      "Bash(gh api:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(ls:*)",
      "Bash(lsd:*)",
      "Bash(rg:*)",
      "Bash(trash:*)",
      "Bash(fd:*)",
      "Bash(npm run*)",
      "Bash(pnpm run*)",
      "Bash(yarn run*)",
      "Bash(moon check*)",
      "Bash(moon fmt*)",
      "Bash(moon info*)",
      "Bash(moon test*)",
      "Bash(deno check*)",
      "Bash(deno fmt*)",
      "Bash(deno info*)",
      "Bash(deno test*)",
      "Read(.env.example)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Read"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(git reset:*)",
      "Bash(git clean -f:*)",
      "Bash(git branch -D:*)",
      "Bash(git restore:*)",
      "Bash(gh auth:*)",
      "Bash(mongod:*)",
      "Bash(supabase reset:*)",
      "Bash(mysql:*)",
      "Bash(nc:*)",
      "Bash(psql:*)",
      "Bash(rm:*)",
      "Bash(sudo:*)",
      "Bash(wget:*)",
      "Read(**/.ssh/**)",
      "Read(.env)",
      "Write(.env)",
      "NotebookEdit",
      "WebSearch",
      "WebFetch"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/guard-commands.sh",
            "if": "Bash(find *)"
          },
          {
            "type": "command",
            "command": "~/.local/bin/guard-commands.sh",
            "if": "Bash(rm *)"
          },
          {
            "type": "command",
            "command": "~/.local/bin/guard-commands.sh",
            "if": "Bash(grep *)"
          },
          {
            "type": "command",
            "command": "~/.local/bin/guard-commands.sh",
            "if": "Bash(git push *)"
          },
          {
            "type": "command",
            "command": "~/.local/bin/guard-commands.sh",
            "if": "Bash(git reset --hard *)"
          },
          {
            "type": "command",
            "command": "~/.local/bin/guard-commands.sh",
            "if": "Bash(git clean -fd *)"
          },
          {
            "type": "command",
            "command": "~/.local/bin/guard-commands.sh",
            "if": "Bash(git clean -f *)"
          },
          {
            "type": "command",
            "command": "~/.local/bin/guard-commands.sh",
            "if": "Bash(git branch -D *)"
          },
          {
            "type": "command",
            "command": "~/.local/bin/guard-commands.sh",
            "if": "Bash(git checkout \\. *)"
          },
          {
            "type": "command",
            "command": "~/.local/bin/guard-commands.sh",
            "if": "Bash(git restore \\. *)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_CONFIG_DIR/hooks/lint-github-actions.sh",
            "if": "Edit(**/.github/workflows/*.yml)"
          },
          {
            "type": "command",
            "command": "$CLAUDE_CONFIG_DIR/hooks/lint-github-actions.sh",
            "if": "Edit(**/.github/workflows/*.yaml)"
          },
          {
            "type": "command",
            "command": "$CLAUDE_CONFIG_DIR/hooks/lint-github-actions.sh",
            "if": "Write(**/.github/workflows/*.yml)"
          },
          {
            "type": "command",
            "command": "$CLAUDE_CONFIG_DIR/hooks/lint-github-actions.sh",
            "if": "Write(**/.github/workflows/*.yaml)"
          },
          {
            "type": "command",
            "command": "$CLAUDE_CONFIG_DIR/hooks/lint-shell.sh",
            "if": "Edit(**/*.sh)"
          },
          {
            "type": "command",
            "command": "$CLAUDE_CONFIG_DIR/hooks/lint-shell.sh",
            "if": "Write(**/*.sh)"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_CONFIG_DIR/hooks/notify.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$CLAUDE_CONFIG_DIR/statusline.py"
  },
  "enabledPlugins": {
    "security-guidance@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "discord@claude-plugins-official": true,
    "aws-serverless@agent-plugins-for-aws": true,
    "databases-on-aws@agent-plugins-for-aws": true,
    "deploy-on-aws@agent-plugins-for-aws": true,
    "migration-to-aws@agent-plugins-for-aws": true,
    "codex@openai-codex": true,
    "supabase@claude-plugins-official": true,
    "chrome-devtools-mcp@chrome-devtools-plugins": true,
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "agent-plugins-for-aws": {
      "source": {
        "source": "github",
        "repo": "awslabs/agent-plugins"
      }
    },
    "laravel": {
      "source": {
        "source": "github",
        "repo": "laravel/agent-skills"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "chrome-devtools-plugins": {
      "source": {
        "source": "github",
        "repo": "ChromeDevTools/chrome-devtools-mcp"
      }
    }
  },
  "language": "japanese",
  "effortLevel": "high",
  "advisorModel": "opus",
  "plansDirectory": ".agents/plans",
  "theme": "auto",
  "agentPushNotifEnabled": true
}
